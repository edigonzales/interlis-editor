    "@theia/editor": "1.65.0",
    "@theia/electron": "1.65.0",
    "@theia/filesystem": "1.65.0",
    "@theia/monaco": "1.65.0",
    "@theia/navigator": "1.65.0",
    "@theia/preferences": "1.65.0",
    "@theia/terminal": "1.65.0",
    "@theia/workspace": "1.65.0",
    "electron": "37.2.1"
  },
  "devDependencies": {
    "@theia/cli": "1.65.0"
  }
}
